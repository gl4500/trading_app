# ============================================================
# AI Trading Competition - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Alpaca Markets (Paper Trading) ──────────────────────────
# Get your keys at: https://app.alpaca.markets/paper-trading
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── AI API Keys ─────────────────────────────────────────────
# Anthropic: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── FRED (Federal Reserve Economic Data) ─────────────────────
# Free API key: https://fred.stlouisfed.org/docs/api/api_key.html
# Provides: CPI, unemployment, Fed funds rate, yield curve, recession probability
# Leave empty to disable (app runs fine without it)
FRED_API_KEY=

# ── Massive.com (market data, macro context, S3 flat files) ──
# Get your key at: https://massive.com/dashboard
MASSIVE_API_KEY=your_massive_api_key_here
MASSIVE_S3_BUCKET=your_s3_bucket_name
MASSIVE_S3_ACCESS_KEY=your_s3_access_key
MASSIVE_S3_SECRET_KEY=your_s3_secret_key
MASSIVE_S3_REGION=us-east-1

# ── OpenClaw Local Model Gateway ─────────────────────────────
# Run: openclaw start  (then set the model you have loaded)
OPENCLAW_BASE_URL=http://127.0.0.1:18789/v1
OPENCLAW_TOKEN=your_openclaw_gateway_token
OPENCLAW_MODEL=llama3.2

# ── Trading Parameters ───────────────────────────────────────
STARTING_CAPITAL=100000
MAX_POSITION_SIZE=0.15
TRADE_INTERVAL_SECONDS=60
DAILY_LOSS_LIMIT=0.05
ANNUAL_GOAL=50000

# ── AI Agent Call-Rate Limits (cloud mode only) ──────────────
# Claude Opus 4.6 — 10/hr lets the 5-cycle interval control cadence
CLAUDE_HOURLY_CALL_LIMIT=10
# Gemini Flash — very cheap; 20/hr gives near-continuous analysis
GEMINI_HOURLY_CALL_LIMIT=20

# ── Risk Manager Limits ──────────────────────────────────────
# Minutes before re-buying a symbol after selling (churn prevention)
CHURN_COOLOFF_MINUTES=30
# Max fraction of portfolio in a single sector (0.35 = 35%)
SECTOR_CONCENTRATION_LIMIT=0.35
# Max average pairwise Pearson correlation across held positions
CORRELATION_LIMIT=0.65
# Sell when bayes_confidence drops this far below entry_confidence (0.30 = 30pp)
BAYES_EXIT_DROP=0.30

# Trailing stop on UNREALIZED PnL — locks in gains by selling positions
# that have given back X% of their peak unrealized profit.
#   TRAIL_GIVEBACK_PCT: fraction of peak that triggers exit (0.20 = 20%)
#   TRAIL_ARM_USD:      peak must reach this $ amount before trailing arms
#                       (avoids whipsaw on small noise around break-even)
TRAIL_GIVEBACK_PCT=0.20
TRAIL_ARM_USD=25.0

# Hard stop-loss — defensive floor independent of Bayes / trailing / LLM.
# Sells when (avg_cost - current_price) / avg_cost >= HARD_STOP_PCT.
# Catches positions that drop sharply from entry without ever being
# profitable (the case the trailing stop can't catch). Set to 0 to disable.
HARD_STOP_PCT=0.08

# Lone-wolf discount — when CNNReasoningAgent fires a BUY but fewer than
# LONEWOLF_MIN_CORROBORATORS other agents are also BUYing the same symbol,
# multiply size_pct by LONEWOLF_MULTIPLIER. Caps damage when CNN's noise-
# fitting tendency produces false positives the rest of the ensemble doesn't see.
LONEWOLF_MIN_CORROBORATORS=2
LONEWOLF_MULTIPLIER=0.5

# Daily-move risk re-evaluation — when a held position drops more than
# DAILY_REVIEW_PCT from today's open, inject a "## RISK ALERT" block into
# the Ollama prompt so the LLM is forced to explicitly reconsider whether
# to exit. Also bypasses the entropy pre-filter so the LLM is consulted
# even when source magnitudes are low. Set to 0 to disable.
DAILY_REVIEW_PCT=0.05

# GPU/Ollama coordination across apps (Backlog 0.7) — shared coord file
# at this path tracks each app's deployed capital so the higher-exposure
# app gets priority on the next Ollama call. Defaults to
# ~/.ollama-coord/state.json. polymarket_app must also be wired into the
# same file for cross-app priority to take effect; trading_app alone uses
# only the per-app asyncio.Lock for in-process serialization.
# OLLAMA_COORD_FILE=

# ── Model backend selector (added 2026-05-02) ──────────────────────────────
# Pick which signal model the CNN agent uses.
#   cnn     → temporal CNN (legacy default)
#   xgboost → XGBoost regressor on flattened (C×T) features
# Switch this to A/B the two on the same walk-forward harness.
MODEL_BACKEND=cnn

# XGBoost hyperparameters (only consulted when MODEL_BACKEND=xgboost).
# All env-overridable; defaults documented in
# docs/superpowers/plans/2026-05-02-xgboost-model-backend.md.
XGB_N_ESTIMATORS=500
XGB_MAX_DEPTH=6
XGB_LEARNING_RATE=0.05
XGB_SUBSAMPLE=0.8
XGB_COLSAMPLE_BYTREE=0.8
XGB_REG_ALPHA=0.1
XGB_REG_LAMBDA=1.0
XGB_EARLY_STOPPING=30

# ── Watchlist (comma-separated tickers) ─────────────────────
WATCHLIST=AAPL,MSFT,GOOGL,TSLA,AMZN,NVDA,META,SPY

# ── Authentication ───────────────────────────────────────────
# Leave APP_PASSWORD empty to disable auth (open-access, local use only).
# Set a strong password to require login before accessing the dashboard.
APP_PASSWORD=

# Auto-generated by setup_fresh.ps1 — do NOT share or commit this value.
# To regenerate: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# ── Ollama (local LLM — free, no API key required) ───────────
# Install Ollama from https://ollama.com  then run: ollama pull qwen2.5:7b
# Set OLLAMA_ONLY_MODE=1 to run all AI agents locally (zero cloud cost).
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_ONLY_MODE=0

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WS_UPDATE_INTERVAL=5
