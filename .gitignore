# Secrets - NEVER commit these
.env
certs/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Database - contains trading data
trading.db
backend/trading.db
backend/learning.json
backend/data/scan_cache.json
backend/data/agent_picks.json

# Runtime & deps (large binaries — downloaded by scripts/setup_fresh.ps1)
site-packages/
runtime/

# Offline wheel cache — committed so setup_fresh.ps1 can fall back to local install
# (torch wheels are NOT included — too large; setup_fresh.ps1 downloads torch from PyPI)
# backend/packages/  ← intentionally NOT excluded

# Node
frontend/node_modules/
frontend/dist/

# PyInstaller
build/
dist/
*.spec
# Keep the launcher spec — it's the build recipe for Start Trading App.exe
!launcher_gui.spec

# Misc
*.log
.DS_Store
Thumbs.db
